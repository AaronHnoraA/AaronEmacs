#import "/_typst/beamer.typ": *

#show: note-slide-theme

#note-title-slide(
  "{{title}}",
  subtitle: "Working notes",
  author: "{{author}}",
  date: "{{date}}",
)

#agenda((
  [Problem],
  [Core idea],
  [Evidence],
  [Takeaway],
))

#slide[
  = Problem

  {{cursor}}

  - What is the audience currently missing?
  - Why does it matter now?
]

#slide[
  = Core Idea

  - Claim:
  - Construction:
  - Intuition:
]

#slide[
  = Evidence

  - Theorem / experiment:
  - Example:
  - Limitation:
]

#slide[
  = Takeaway

  - What should be remembered?
  - What should happen next?
]
