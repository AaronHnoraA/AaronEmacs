# Emacs compiled files
*.elc
*.eln

# Emacs package management
/elpa/
/quelpa/
/package-quickstart.el
/.cask

# Emacs runtime state and caches
/eln-cache/
/var/
/etc/
/tree-sitter/
/undo-tree-history/
/auto-save-list/
/eshell/
/request/
/server/
/transient/
/url/
/places
/recentf
/savehist
/network-security.data
/projectile-bookmarks.eld
/bookmarks
/bookmarks~
/session.*
/semanticdb/

# Project-local data produced by this config
/Org/
/eaf/

# Python caches from local helper scripts
__pycache__/
*.py[cod]

# Backup, autosave, lock, and transient files
*~
\#*\#
.\#*
*.~undo-tree
.flycheck*

# Shell init files kept only on the local machine
/init_bash.sh
/init_zsh.sh

# OS junk
.DS_Store
