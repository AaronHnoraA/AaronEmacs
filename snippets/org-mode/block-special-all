# -*- mode: snippet -*-
# name: org special block (scripted; cached choice)
# key: ;b
# --
`(let* ((blk (yas-choose-value
              '("definition" "defn" "theorem" "thm" "lemma"
                "cor" "prop" "property" "proof" "example"
                "attention" "note" "info" "warning"))))
   (insert (concat "#+begin_" blk "\n\n#+end_" blk)))`
